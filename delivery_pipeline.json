{
  "output_dir": "delivery_pipeline_output",
  "approvals": {
    "base_dir": "delivery_pipeline_output/approvals",
    "default_suffix": ".ok"
  },
  "versioning": {
    "strategy": "git_or_timestamp",
    "prefix": "v",
    "file": "VERSION",
    "write_file": true,
    "location": "output"
  },
  "overlay_solver_workspace": true,
  "require_solver_completion": false,
  "clean_workspaces": false,
  "rag": {
    "enabled": true,
    "auto_sources": true,
    "max_docs": 40,
    "chunk_size": 1200,
    "chunk_overlap": 200
  },
  "mcp": {
    "servers": []
  },
  "stages": [
    {
      "name": "sandbox",
      "description": "Isolated unit tests in a clean workspace",
      "workspace_mode": "copy",
      "commands": [
        "python -m venv .venv",
        ".venv/bin/python -m pip install -r requirements.txt",
        ".venv/bin/python -m pytest -q"
      ],
      "artifacts": [
        "coverage.xml"
      ],
      "kind": "test"
    },
    {
      "name": "dev",
      "description": "Developer integration checks in the project workspace",
      "workspace_mode": "project",
      "commands": [
        "python -m pytest -q"
      ],
      "kind": "test"
    },
    {
      "name": "integration",
      "description": "Integration testing and service-level checks",
      "workspace_mode": "copy",
      "commands": [
        "python -m pytest -q -m integration"
      ],
      "kind": "test"
    },
    {
      "name": "security_scan",
      "description": "Security and dependency scanning",
      "workspace_mode": "copy",
      "commands": [
        "if command -v pip-audit >/dev/null 2>&1; then if [ -f requirements.txt ]; then pip-audit -r requirements.txt; elif [ -f requirements-dev.txt ]; then pip-audit -r requirements-dev.txt; elif [ -f pyproject.toml ] || [ -f setup.py ] || [ -f setup.cfg ]; then pip-audit; else echo \"pip-audit skipped: no Python dependency files\"; fi; else echo \"pip-audit not installed; skipping\"; fi",
        "if command -v npm >/dev/null 2>&1; then if [ -f package-lock.json ] || [ -f npm-shrinkwrap.json ]; then npm audit --audit-level=high; else echo \"npm audit skipped: no lockfile\"; fi; else echo \"npm not installed; skipping\"; fi",
        "if command -v trivy >/dev/null 2>&1; then trivy fs --scanners vuln,secret,config --severity HIGH,CRITICAL --exit-code 1 .; else echo \"trivy not installed; skipping\"; fi"
      ],
      "remediation": [
        "if command -v pip-audit >/dev/null 2>&1; then if [ -f requirements.txt ]; then pip-audit --fix -r requirements.txt; elif [ -f requirements-dev.txt ]; then pip-audit --fix -r requirements-dev.txt; elif [ -f pyproject.toml ] || [ -f setup.py ] || [ -f setup.cfg ]; then pip-audit --fix; else echo \"pip-audit fix skipped: no Python dependency files\"; fi; else echo \"pip-audit not installed; skipping\"; fi",
        "if command -v npm >/dev/null 2>&1; then if [ -f package-lock.json ] || [ -f npm-shrinkwrap.json ]; then npm audit fix || npm audit fix --force; else echo \"npm audit fix skipped: no lockfile\"; fi; else echo \"npm not installed; skipping\"; fi",
        "if command -v trivy >/dev/null 2>&1; then trivy --download-db-only; else echo \"trivy not installed; skipping\"; fi"
      ],
      "kind": "security"
    },
    {
      "name": "interim_deploy",
      "kind": "sandbox_deploy",
      "description": "Optional interim deploy for sandbox validation",
      "workspace_mode": "copy",
      "enabled": false,
      "commands": [
        "echo \"Interim deploy step goes here\""
      ]
    },
    {
      "name": "interim_teardown",
      "kind": "teardown",
      "description": "Optional teardown after interim deploy",
      "workspace_mode": "copy",
      "enabled": false,
      "commands": [
        "echo \"Interim teardown step goes here\""
      ]
    },
    {
      "name": "staging",
      "description": "Staging build and smoke tests",
      "workspace_mode": "copy",
      "requires_approval": true,
      "commands": [
        "python -m pytest -q -m smoke"
      ],
      "artifacts": [
        "dist",
        "build"
      ],
      "kind": "staging"
    },
    {
      "name": "canary",
      "description": "Canary release validation",
      "workspace_mode": "project",
      "requires_approval": true,
      "commands": [
        "echo \"Canary deploy step goes here\""
      ],
      "kind": "canary",
      "rag": {
        "query": "canary deployment runbook checklist",
        "context_file": "delivery_pipeline_output/rag/canary_context.md"
      },
      "mcp_calls": [
        {
          "name": "create_canary_change",
          "server": "change_mgmt",
          "tool": "change/create",
          "arguments": {
            "title": "Canary release {version}",
            "stage": "{stage}",
            "project": "{project_root}"
          },
          "when": "pre",
          "required": false
        }
      ]
    },
    {
      "name": "uat",
      "description": "User acceptance testing",
      "workspace_mode": "copy",
      "requires_approval": true,
      "commands": [],
      "kind": "uat"
    },
    {
      "name": "deploy",
      "description": "Deployment step (replace with deployment command)",
      "workspace_mode": "project",
      "requires_approval": true,
      "commands": [
        "echo \"Deploy step goes here\""
      ],
      "kind": "deploy",
      "rag": {
        "query": "deployment runbook and release checklist",
        "context_file": "delivery_pipeline_output/rag/deploy_context.md"
      },
      "mcp_calls": [
        {
          "name": "announce_release",
          "server": "release_ops",
          "tool": "release/announce",
          "arguments": {
            "version": "{version}",
            "notes_path": "{output_dir}/rag/deploy_context.md"
          },
          "when": "post",
          "required": false
        }
      ]
    }
  ],
  "vcs": {
    "enabled": true,
    "provider": "github",
    "base_url": "https://github.com",
    "owner": "neuralmimicry",
    "repo": "refiner",
    "remote": "origin",
    "default_branch": "main",
    "ensure_remote": true,
    "require_clean": true,
    "block_on_failure": true,
    "actions": [
      {
        "type": "pull"
      },
      {
        "type": "branch",
        "name": "solver/{version}",
        "checkout": true
      },
      {
        "type": "commit",
        "message": "chore: solver {version}",
        "paths": [
          "."
        ]
      },
      {
        "type": "merge",
        "source": "solver/{version}",
        "target": "main",
        "checkout_target": true,
        "no_ff": true,
        "enabled": false
      },
      {
        "type": "push",
        "set_upstream": true
      },
      {
        "type": "tag",
        "name": "v{version}",
        "message": "release {version}",
        "push": true
      },
      {
        "type": "release",
        "tag": "v{version}",
        "use_gh": false,
        "notes_file": "CHANGELOG.md",
        "enabled": false
      }
    ]
  },
  "platform": {
    "auto": true,
    "preferred_order": [
      "local",
      "container",
      "k8s",
      "openshift",
      "cloud"
    ],
    "container_preference": [
      "podman",
      "docker"
    ],
    "cloud_preference": [
      "gcp",
      "aws",
      "azure"
    ],
    "require_emulation": false
  },
  "solver_gate": "block_deploy",
  "allow_unfinished_deploy": false,
  "auto_recover": true,
  "retry_attempts": 1,
  "retry_delay_sec": 2,
  "solver_fallback": {
    "enabled": true,
    "max_attempts": 2,
    "on_failure_types": [
      "test_failure",
      "pytest_import_error"
    ],
    "requirements_only": true,
    "allow_run": false,
    "max_steps": 25,
    "max_iterations": 2,
    "use_workspace": true
  }
}
