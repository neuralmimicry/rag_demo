# /etc/default/refiner-stt
# Native on-prem arm64 Ubuntu preset for a 46-core host.

REFINER_STT_MODEL=/opt/refiner/models/ggml-base.en.bin
REFINER_STT_BIND=127.0.0.1:7079
REFINER_STT_LANG=en-GB
REFINER_STT_THREADS=2
REFINER_STT_WORKERS=23
REFINER_STT_MAX_AUDIO_BYTES=8000000
REFINER_STT_BUILTIN_CONTEXT_ENABLED=1
REFINER_STT_PROMPT_ALLOW_CLIENT=0
REFINER_STT_CANONICALIZE_ENTITIES=1

# Keep the async runtime responsive under concurrent uploads.
TOKIO_WORKER_THREADS=46
RUST_LOG=info
RUST_BACKTRACE=1

# Lower-memory fallback (bigger models):
# REFINER_STT_THREADS=4
# REFINER_STT_WORKERS=11
