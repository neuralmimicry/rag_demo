# Whisper.cpp preset for Refiner STT (command backend)
# Assumes whisper.cpp is built and available at /opt/whisper.cpp/main
# Produces JSON at {audio}.json which Refiner will read.

REFINER_STT_BACKEND=command
REFINER_STT_COMMAND=/opt/whisper.cpp/main
REFINER_STT_ARGS="-m /opt/models/ggml-base.en.bin -f {audio} -l {lang} -oj -of {audio}"
REFINER_STT_OUTPUT=json
REFINER_STT_OUTPUT_PATH={audio}.json

# Optional if audio is not already 16k mono wav
REFINER_STT_PREPROCESS_COMMAND=ffmpeg
REFINER_STT_PREPROCESS_ARGS="-y -i {input} -ar 16000 -ac 1 {output}"
REFINER_STT_PREPROCESS_EXT=.wav
