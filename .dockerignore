# .git is intentionally included in the build context so container images can
# stamp commit-based build metadata for the runtime version badge and API.
.gitignore
__pycache__/
.pytest_cache/
.venv/
venv/
*.pyc
*.pyo
*.pyd
*.log
.mypy_cache/
.idea/
.vscode/
node_modules/
target/
stt_rust/target/
dist/
job_data/
output.md
confluence_report.html
jira_report.html
kpis.html
gantt_projects.html
data/
